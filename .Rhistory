shinyApp(ui, server)
ggplot(data=bikesub, aes(x=temperature)) +
geom_histogram(binwidth = 3, fill="blue", alpha=0.6)
# install.packages("tidyverse")
library(tidyverse)
library(ggplot2)
library(dplyr)
setwd("~/Uni/1 Master Statistik/R")
bikedata <- read.csv("bikedata.csv")
ggplot(data=bikedata, mapping=aes(x=temperature, y=wind_speed)) +
geom_point()
library("ggplot2")
datasets <- c("economics", "faithfuld", "seals")
ui <- fluidPage(
selectInput("data", "Dataset", choices = datasets),
tableOutput("plot")
)
server <- function(input, output, session) {
dataset <- reactive({
get(input$dataset, "package:ggplot2")
})
output$plot <- renderPlot({
plot(dataset)
}, res = 96)
}
shinyApp(ui, server)
set.seed(999)
bikedata5000 <- bikedata[sample(nrow(bikedata),5000),]
bikedata5000
ggplot(data=bikedata5000, mapping=aes(x=wind_speed, y=temperature)) +
geom_point()
ggplot(bikedata5000, mapping=aes(x=wind_speed, y=temperature)) +
geom_point(color="lightpink", fill="lightpink", shape=22,
size=1, alpha=0.5)
bikedata%>%
select(cyclists, temperature, weekday) %>%
mutate("season" = case_when(
temperature < 10 ~ "Cold",
temperature < 20 ~ "Mild",
TRUE ~ "Warm"
)) %>%
group_by(season)  %>%
summarise(mean_cyclists=mean(cyclists), max_cyclists=max(cyclists))
bikedata%>%
select(cyclists, temperature, weekday) %>%
mutate(is_weekend = weekday %in% c("Sat","Sun")) %>%
group_by(is_weekend)  %>%
summarise(mean_cyclists=mean(cyclists), max_cyclists=max(cyclists))
library(shiny)
library(bslib)
library(dplyr)
library(ggplot2)
library(plotly)
library(lubridate)
